GEMINI_API_KEY=your_gemini_api_key_here

# Razorpay settings (DO NOT commit live keys!)
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret_here

# Valid activation codes for premium (comma separated)
VALID_ACTIVATION_CODES=TENDERMASTERPRO,ANOTHERCODE

# First superadmin email for bootstrapping
SUPERADMIN_EMAIL=your_email@example.com
